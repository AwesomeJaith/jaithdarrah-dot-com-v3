{
  "env": { "ENABLE_LSP_TOOL": "1" },
  "permissions": {
    "allow": [
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm lint:*)",
      "Bash(npx prettier:*)",
      "Bash(pnpm format:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(ag:*)",
      "Bash(fd:*)",
      "Bash(locate:*)",
      "Bash(which:*)",
      "Bash(whereis:*)",
      "Read",
      "Glob",
      "Grep",
      "mcp__ide__getDiagnostics"
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  }
}
